# Database Configuration
PGHOST=localhost
PGPORT=5432
PGDATABASE=PureFormDB
PGUSER=postgres
PGPASSWORD=your_password_here

# Optional: full connection string (e.g., Neon)
DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require

# Docker Postgres container defaults
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=PureFormDB
POSTGRES_USER=postgres

# JWT Configuration
JWT_KEY=your_very_long_and_random_jwt_key_at_least_32_characters_long
JWT_ISSUER=PureFormAPI
JWT_AUDIENCE=PureFormClient

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend.vercel.app

# Stripe Configuration (Optional)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
STRIPE_PRICE_ID=price_your_price_id

# Application Environment
ASPNETCORE_ENVIRONMENT=Production
